{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "https://nenekbot.onrender.com/"
    },
    {
      "source": "/:path*",
      "destination": "https://nenekbot.onrender.com/:path*"
    }
  ]
}
